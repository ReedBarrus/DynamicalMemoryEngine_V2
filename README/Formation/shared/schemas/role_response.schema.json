{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "role_response.schema.json",
  "title": "Role Response",
  "type": "object",
  "required": [
    "pass_id",
    "role",
    "active_subject_id",
    "state_before",
    "state_after",
    "mutated_live_surface",
    "accepted_changes",
    "rejected_changes",
    "live_tensions",
    "cycle_log_entry",
    "recommended_next_role",
    "recommended_next_state"
  ],
  "properties": {
    "pass_id": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "constructor",
        "creative",
        "reflector",
        "auditor_gate"
      ]
    },
    "active_subject_id": {
      "type": "string"
    },
    "state_before": {
      "type": "string",
      "enum": [
        "seeded",
        "tension_held",
        "compressed",
        "gate_pending",
        "released",
        "hold",
        "metastable_hold",
        "deferred",
        "downgraded",
        "rebound",
        "archived"
      ]
    },
    "state_after": {
      "type": "string",
      "enum": [
        "seeded",
        "tension_held",
        "compressed",
        "gate_pending",
        "released",
        "hold",
        "metastable_hold",
        "deferred",
        "downgraded",
        "rebound",
        "archived"
      ]
    },
    "mutated_live_surface": {
      "type": "boolean"
    },
    "live_surface_patch": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "replace_section",
            "append_section",
            "no_mutation"
          ]
        },
        "section_anchor": {
          "type": "string"
        },
        "new_text": {
          "type": "string"
        }
      },
      "required": [
        "mode"
      ],
      "additionalProperties": true
    },
    "accepted_changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rejected_changes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "live_tensions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "write_payload_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cycle_log_entry": {
      "$ref": "cycle_log_entry.schema.json"
    },
    "recommended_next_role": {
      "type": "string"
    },
    "recommended_next_state": {
      "type": "string",
      "enum": [
        "seeded",
        "tension_held",
        "compressed",
        "gate_pending",
        "released",
        "hold",
        "metastable_hold",
        "deferred",
        "downgraded",
        "rebound",
        "archived"
      ]
    },
    "gate_decision": {
      "$ref": "gate_decision.schema.json"
    },
    "subject_register_update": {
      "type": "object",
      "properties": {
        "subject_id": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "seeded",
            "tension_held",
            "compressed",
            "gate_pending",
            "released",
            "hold",
            "metastable_hold",
            "deferred",
            "downgraded",
            "rebound",
            "archived"
          ]
        },
        "next_active_subject_id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}