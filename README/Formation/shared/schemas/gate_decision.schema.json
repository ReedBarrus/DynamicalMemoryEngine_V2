{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gate_decision.schema.json",
  "title": "Gate Decision",
  "type": "object",
  "required": [
    "pass_id",
    "role",
    "active_subject_id",
    "structural_gain_judgment",
    "decision",
    "next_layer",
    "next_active_subject_id",
    "reason"
  ],
  "properties": {
    "pass_id": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "const": "auditor_gate"
    },
    "active_subject_id": {
      "type": "string"
    },
    "structural_gain_judgment": {
      "type": "string",
      "enum": [
        "descend",
        "metastable_hold",
        "compress_upward",
        "unclear"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "release",
        "hold",
        "defer",
        "downgrade",
        "rebound"
      ]
    },
    "next_layer": {
      "type": "string",
      "enum": [
        "same",
        "deeper",
        "prior"
      ]
    },
    "next_active_subject_id": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "subject_register_update": {
      "type": "object",
      "properties": {
        "subject_id": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "seeded",
            "tension_held",
            "compressed",
            "gate_pending",
            "released",
            "hold",
            "metastable_hold",
            "deferred",
            "downgraded",
            "rebound",
            "archived"
          ]
        },
        "next_active_subject_id": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}