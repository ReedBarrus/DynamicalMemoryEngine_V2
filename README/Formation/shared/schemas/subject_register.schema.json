{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "subject_register.schema.json",
  "title": "Subject Register",
  "type": "object",
  "required": [
    "active_subject_id",
    "subjects"
  ],
  "properties": {
    "active_subject_id": {
      "type": "string"
    },
    "subjects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "subject_id",
          "title",
          "layer",
          "state",
          "eligible_next_subjects",
          "release_criteria",
          "known_tensions",
          "last_role",
          "recommended_next_role",
          "notes"
        ],
        "properties": {
          "subject_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "layer": {
            "type": "string"
          },
          "state": {
            "type": "string",
            "enum": [
              "seeded",
              "tension_held",
              "compressed",
              "gate_pending",
              "released",
              "hold",
              "metastable_hold",
              "deferred",
              "downgraded",
              "rebound",
              "archived"
            ]
          },
          "parent_subject_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "eligible_next_subjects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "release_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "known_tensions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_role": {
            "type": "string"
          },
          "recommended_next_role": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}